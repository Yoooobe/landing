# Google AI Studio / Gemini API — mesmo valor que em Vercel → Environment Variables
GEMINI_API_KEY=

# Opcional: o SDK @google/genai também aceita GOOGLE_API_KEY
# GOOGLE_API_KEY=

# Opcional: origens CORS (vírgula). Por defeito inclui GitHub Pages do Studio e localhost.
# ALLOWED_ORIGINS=https://yoooobe.github.io,http://localhost:3000
