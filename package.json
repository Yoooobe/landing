{
  "name": "my-next-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "generate:llms": "npx tsx scripts/generate-llms-txt.ts",
    "build": "npm run generate:llms && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "seed:sanity": "node scripts/seed-sanity-content.mjs",
    "sanity:cors": "sanity cors add http://localhost:3000 && sanity cors add http://127.0.0.1:3000",
    "deploy:gh-pages": "bash scripts/deploy-gh-pages.sh",
