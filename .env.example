# Copia para `.env.local` e preenche (não commits `.env.local`).
# Studio + fetch Sanity: precisas de ID real — "placeholder" não conta como ligado.
#
# ID do projeto: https://www.sanity.io/manage → projeto → Project settings

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Opcional (já tem default no código)
# NEXT_PUBLIC_SANITY_API_VERSION=2024-03-17

# URL canónica do site (GitHub Pages default no código; override se necessário)
# NEXT_PUBLIC_SITE_URL=https://yoooobe.github.io/landing/
