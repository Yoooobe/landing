# =============================================================================
# Landing + Sanity Studio — copia para .env.local e preenche:
#   npm run env:init
#   npm run env:check
# =============================================================================
# Nunca commits .env.local (já está no .gitignore).

# --- Site (define o basePath, ex. /landing) ---------------------------------
# Local: espelha produção em plataforma.4unik.com.br/landing
NEXT_PUBLIC_SITE_URL=http://localhost:3000/landing

# --- Sanity (obrigatório para o Studio em /landing/studio/) -----------------
# Project ID: https://www.sanity.io/manage → o teu projeto → Project settings
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-03-17

# --- Nano Banana (opcional — geração de imagens no Studio) -------------------
# URL pública do endpoint POST { "prompt" } (sem chaves secretas aqui).
SANITY_STUDIO_NANO_BANANA_URL=https://nano-banana-api-pi.vercel.app/api/generate

# --- Analytics (opcional) -----------------------------------------------------
# GA4 Measurement ID — produção: G-SMJDYCENBC (conta 4unik / propriedade 327916606)
# Ver docs/knowledge-base/integrations.md
NEXT_PUBLIC_GA_ID=G-SMJDYCENBC
# Google Tag Manager (opcional — só se env não definido, usa Sanity siteSettings)
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# Meta Pixel (opcional)
# NEXT_PUBLIC_META_PIXEL_ID=
# LinkedIn Insight Tag (opcional)
# NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# --- Search Console (opcional — verificação HTML tag) -------------------------
# Conteúdo do meta google-site-verification (só o token, sem o nome do atributo).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- Páginas de crescimento (pricing, segurança) ------------------------------
# true só após gate em docs/content-approval-queue.md — inclui rotas no sitemap e robots index
# NEXT_PUBLIC_INDEX_GROWTH_PAGES=true


# --- Etiqueta de ambiente (opcional, UI) ------------------------------------
# NEXT_PUBLIC_ENVIRONMENT_LABEL=local

# --- Apenas scripts (seed, MCP, blog) — não necessário só para abrir Studio --
# Token de escrita (criar em https://www.sanity.io/manage → projeto → API → Tokens).
# Permissões: Editor (ou superior) para criar/atualizar documentos e fazer upload de assets.
# Os scripts de blog (`npm run generate:blog-posts`, `sync:blog-fallback`) aceitam qualquer um:
# SANITY_API_TOKEN=sk...
# SANITY_API_WRITE_TOKEN=sk...
# SANITY_AUTH_TOKEN=          # usado por alguns scripts legacy (ex.: seed como fallback)
# SANITY_API_READ_TOKEN=        # opcional: drafts no preview local (só leitura)
# OPENAI_API_KEY=               # só para o agente de geração de posts do blog

# --- Leads / chat (opcional) -------------------------------------------------
# Produção (GitHub secret ou export local antes do build):
# NEXT_PUBLIC_LEADS_INGEST_URL=https://leads-ingest-api.vercel.app/api/ingest
# NEXT_PUBLIC_CHAT_SCRIPT_URL=
