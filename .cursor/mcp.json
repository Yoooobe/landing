{
  "mcpServers": {
    "gemini-mcp-tool": {
      "command": "npx",
      "args": [
        "-y",
        "gemini-mcp-tool"
      ],
      "env": {
        "GEMINI_API_KEY": "${env:GOOGLE_API_KEY}"
      }
    },
    "4unik-marketing": {
      "command": "node",
      "args": ["${workspaceFolder}/mcps/4unik-marketing/index.js"],
      "cwd": "${workspaceFolder}/mcps/4unik-marketing",
      "env": {
        "GA_PROPERTY_ID": "327916606",
        "GA4_STREAM_ID": "15052677461",
        "GA4_HOSTNAME": "plataforma.4unik.com.br",
        "SITE_URL": "https://plataforma.4unik.com.br/landing",
        "GOOGLE_APPLICATION_CREDENTIALS": "/Users/genautech/.config/4unik/landing-ga4-reader.json"
      }
    }
  }
}
